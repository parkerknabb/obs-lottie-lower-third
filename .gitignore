# Exclude everything
/*

# Except for default project files
!/.github
!/.gitmodules
!/build-aux
!/cmake
!/data
!/deps
!/src
!/third_party
!.clang-format
!.gersemirc
!.gitignore
!buildspec.json
!CMakeLists.txt
!CMakePresets.json
!LICENSE
!README.md

# Exclude lock files
*.lock.json

# Exclude macOS legacy resource forks
.DS_Store

# Exclude local source backups
/src/old/
src/* copy*.c
src/*[?].c

# Exclude CMake build number cache
/cmake/.CMakeBuildNumber
